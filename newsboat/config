# general settings
auto-reload yes
reload-time 90
max-items 500
reload-threads 8
confirm-mark-feed-read no
cleanup-on-quit yes
prepopulate-query-feeds yes
show-read-feeds no
show-read-articles no

# browser — urlhandler dispatches by URL type (mpv, imv, firefox)
browser "urlhandler %u"
macro v set browser "setsid -f mpv --really-quiet %u >/dev/null 2>&1 &" ; open-in-browser ; set browser "urlhandler %u"
macro o set browser "setsid -f firefox %u >/dev/null 2>&1 &" ; open-in-browser ; set browser "urlhandler %u"
macro i set browser "reddit-img %u &" ; open-in-browser ; set browser "urlhandler %u"
macro I pipe-to "reddit-img --html &"

# keybindings
bind-key j down
bind-key k up
bind-key j next articlelist
bind-key k prev articlelist
bind-key J next-feed articlelist
bind-key K prev-feed articlelist
bind-key G end
bind-key g home
bind-key l open
bind-key h quit
bind-key a toggle-article-read
bind-key n next-unread
bind-key N prev-unread
bind-key U show-urls

# colors — generated by matugen from wallpaper
include "~/.config/newsboat/colors"

articlelist-format  "%4i %f %D   %?T?|%-20T|  ?%t"
