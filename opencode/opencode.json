{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "claude-proxy/claude-haiku-4-5-20251001",
  "autoupdate": "notify",
  "provider": {
    "claude-proxy": {
      "npm": "@ai-sdk/anthropic",
      "name": "Claude (via STWork proxy)",
      "options": {
        "baseURL": "http://localhost:42069/v1",
        "apiKey": "proxy-ignored"
      },
      "models": {
        "claude-opus-4-7": {
          "name": "Opus 4.7 (flagship)",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-opus-4-6": {
          "name": "Opus 4.6",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-opus-4-5-20251101": {
          "name": "Opus 4.5",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-opus-4-1-20250805": {
          "name": "Opus 4.1",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-sonnet-4-6": {
          "name": "Sonnet 4.6 (workhorse)",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-sonnet-4-5-20250929": {
          "name": "Sonnet 4.5",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-haiku-4-5-20251001": {
          "name": "Haiku 4.5",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-3-haiku-20240307": {
          "name": "Haiku 3 (Legacy)",
          "limit": {
            "context": 200000,
            "output": 4096
          }
        }
      }
    }
  },
  "instructions": [
    "~/.claude/shared-memory/user-profile.md",
    "~/.claude/shared-memory/user-preferences.md",
    "~/.claude/shared-memory/system-context.md"
  ],
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "git push*": "ask",
      "git push --force*": "deny",
      "git reset --hard*": "ask",
      "sudo *": "ask"
    },
    "webfetch": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      "build/**",
      ".cache/**",
      "**/*.log",
      "**/.opencode/share/**"
    ]
  },
  "share": "disabled",
  "plugin": [
    "@iam-brain/opencode-codex-auth@latest"
  ]
}
