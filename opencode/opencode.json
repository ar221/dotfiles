{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai-codex-proxy/gpt-5.5",
  "small_model": "openai-codex-proxy/gpt-5.4-mini",
  "autoupdate": "notify",
  "provider": {
    "claude-proxy": {
      "npm": "@ai-sdk/anthropic",
      "name": "Claude (manual escalation only — via STWork proxy)",
      "options": {
        "baseURL": "http://localhost:42069/v1",
        "apiKey": "***"
      },
      "models": {
        "claude-opus-4-7": {
          "name": "Opus 4.7 (flagship)",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-opus-4-6": {
          "name": "Opus 4.6",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-opus-4-5-20251101": {
          "name": "Opus 4.5",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-opus-4-1-20250805": {
          "name": "Opus 4.1",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-sonnet-4-6": {
          "name": "Sonnet 4.6 (workhorse)",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-sonnet-4-5-20250929": {
          "name": "Sonnet 4.5",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-haiku-4-5-20251001": {
          "name": "Haiku 4.5",
          "limit": {
            "context": 200000,
            "output": 8192
          }
        },
        "claude-3-haiku-20240307": {
          "name": "Haiku 3 (Legacy)",
          "limit": {
            "context": 200000,
            "output": 4096
          }
        }
      }
    },
    "openai-codex-proxy": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI Codex (via local OAuth proxy)",
      "options": {
        "baseURL": "http://127.0.0.1:10531/v1",
        "apiKey": "not-needed"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5",
          "limit": {
            "context": 272000,
            "output": 8192
          }
        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 272000,
            "output": 8192
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini",
          "limit": {
            "context": 272000,
            "output": 8192
          }
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "limit": {
            "context": 272000,
            "output": 8192
          }
        },
        "gpt-5.3-codex-spark": {
          "name": "GPT-5.3 Codex Spark",
          "limit": {
            "context": 128000,
            "output": 8192
          }
        },
        "gpt-5.2": {
          "name": "GPT-5.2",
          "limit": {
            "context": 272000,
            "output": 8192
          }
        },
        "codex-auto-review": {
          "name": "Codex Auto Review",
          "limit": {
            "context": 272000,
            "output": 8192
          }
        }
      }
    }
  },
  "instructions": [
    "~/.claude/shared-memory/opencode-context.md"
  ],
  "mcp": {
    "vault": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/ayaz/Documents/Ayaz OS"
      ],
      "enabled": true,
      "timeout": 15000
    },
    "projects": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/ayaz/Github"
      ],
      "enabled": true,
      "timeout": 15000
    },
    "stwork": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/ayaz/STWork"
      ],
      "enabled": true,
      "timeout": 15000
    },
    "modding": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/ayaz/Modding"
      ],
      "enabled": true,
      "timeout": 15000
    },
    "scripts": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/ayaz/.local/bin"
      ],
      "enabled": true,
      "timeout": 15000
    },
    "github": {
      "type": "local",
      "command": [
        "bash",
        "-lc",
        "GITHUB_PERSONAL_ACCESS_TOKEN=\"$(gh auth token)\" exec npx -y @modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "timeout": 20000
    },
    "browser": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp",
        "--headless",
        "--isolated",
        "--caps",
        "vision,pdf,devtools",
        "--timeout-action",
        "10000",
        "--timeout-navigation",
        "60000"
      ],
      "enabled": true,
      "timeout": 120000
    }
  },
  "permission": {
    "edit": "allow",
    "bash": {
      "*": "allow",
      "rm -rf *": "ask",
      "git push*": "ask",
      "git push --force*": "deny",
      "git reset --hard*": "ask",
      "sudo *": "ask"
    },
    "webfetch": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      ".git/**",
      "dist/**",
      "build/**",
      ".cache/**",
      "**/*.log",
      "**/.opencode/share/**"
    ]
  },
  "share": "disabled",
  "plugin": [
    "@iam-brain/opencode-codex-auth@latest"
  ]
}
