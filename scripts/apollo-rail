#!/usr/bin/env python3
import json
import os
import signal
import sys
import time
from pathlib import Path
from shutil import get_terminal_size

STATE_MAIN = Path.home() / ".local/state/opencode/statusline-main.json"
STATE_COPILOT = Path.home() / ".local/state/opencode/statusline-copilot.json"
STALE_SECONDS = 5.0
REFRESH_SECONDS = 0.25

COL_BG = "\x1b[48;2;14;11;8m"
COL_PANEL = "\x1b[48;2;28;21;12m"
COL_TEXT = "\x1b[38;2;242;227;198m"
COL_MUTED = "\x1b[38;2;201;178;139m"
COL_AMBER = "\x1b[38;2;255;182;72m"
COL_SAGE = "\x1b[38;2;168;201;123m"
COL_EMBER = "\x1b[38;2;255;90;78m"
COL_TEAL = "\x1b[38;2;111;197;192m"
COL_RESET = "\x1b[0m"

MODEL_LIMITS = {
    "claude-opus-4-7": 200_000,
    "claude-opus-4-6": 200_000,
    "claude-opus-4-5-20251101": 200_000,
    "claude-opus-4-1-20250805": 200_000,
    "claude-sonnet-4-6": 200_000,
    "claude-sonnet-4-5-20250929": 1_000_000,
    "claude-haiku-4-5-20251001": 200_000,
    "claude-3-haiku-20240307": 200_000,
}

MODEL_NAMES = {
    "claude-opus-4-7": "Opus 4.7",
    "claude-opus-4-6": "Opus 4.6",
    "claude-opus-4-5-20251101": "Opus 4.5",
    "claude-opus-4-1-20250805": "Opus 4.1",
    "claude-sonnet-4-6": "Sonnet 4.6",
    "claude-sonnet-4-5-20250929": "Sonnet 4.5",
    "claude-haiku-4-5-20251001": "Haiku 4.5",
    "claude-3-haiku-20240307": "Haiku 3",
}

running = True


def stop(_signum, _frame):
    global running
    running = False


def pid_alive(pid):
    if not isinstance(pid, int) or pid <= 0:
        return False
    try:
        os.kill(pid, 0)
        return True
    except OSError:
        return False


def read_state(path):
    try:
        data = json.loads(path.read_text())
        mtime = path.stat().st_mtime
    except Exception:
        return None
    stale = (time.time() - mtime) > STALE_SECONDS or not pid_alive(data.get("pid"))
    data["_stale"] = stale
    data["_age"] = int(max(0, time.time() - mtime))
    return data


def short(text, width):
    if width <= 0:
        return ""
    if len(text) <= width:
        return text
    if width == 1:
        return "."
    return text[: width - 1] + "."


def fmt_tokens(total):
    if not isinstance(total, int):
        return "--"
    if total >= 1_000_000:
        return f"{total/1_000_000:.1f}M"
    if total >= 1_000:
        return f"{total/1_000:.1f}k"
    return str(total)


def session_status(data):
    if not data:
        return ("offline", COL_MUTED)
    if data.get("_stale"):
        return ("stale", COL_MUTED)
    status = (data.get("session") or {}).get("status") or "unknown"
    if status == "busy":
        return ("thinking", COL_TEAL)
    if status == "idle":
        return ("idle", COL_SAGE)
    if status == "retry":
        return ("retry", COL_AMBER)
    if status == "error":
        return ("error", COL_EMBER)
    return (status, COL_MUTED)


def model_name(data):
    model_id = ((data or {}).get("model") or {}).get("modelID")
    if not model_id:
        return "--"
    return MODEL_NAMES.get(model_id, model_id)


def ctx_percent(data):
    model = (data or {}).get("model") or {}
    model_id = model.get("modelID")
    total = ((model.get("tokens") or {}).get("total"))
    if not isinstance(total, int) or not model_id:
        return "--"
    limit = MODEL_LIMITS.get(model_id, 200_000)
    pct = int(min(100, (total * 100) / max(1, limit)))
    return f"{pct}%"


def lsp_line(data):
    lsp = (data or {}).get("lsp") or {}
    total = lsp.get("total") if isinstance(lsp.get("total"), int) else 0
    connected = lsp.get("connected") if isinstance(lsp.get("connected"), int) else 0
    errors = lsp.get("error") if isinstance(lsp.get("error"), int) else 0
    return f"LSP {connected}/{total} e:{errors}"


def cost_line(data):
    cost = ((data or {}).get("model") or {}).get("cost")
    if isinstance(cost, (int, float)):
        return f"${cost:.3f}"
    return "$--"


def cwd_line(data):
    cwd = ((data or {}).get("session") or {}).get("directory") or (data or {}).get("bootDirectory") or "-"
    return Path(cwd).name or cwd


def styled_line(text, width, fg=COL_TEXT, bg=COL_PANEL):
    clean = short(text, width).ljust(max(0, width))
    return f"{bg}{fg}{clean}{COL_RESET}"


def section(role, data, width, height):
    lines = []
    status, status_color = session_status(data)
    model = model_name(data)
    tokens = fmt_tokens((((data or {}).get("model") or {}).get("tokens") or {}).get("total"))
    ctx = ctx_percent(data)
    cost = cost_line(data)
    cwd = cwd_line(data)
    lsp = lsp_line(data)
    age = f"age {data.get('_age', 0)}s" if data else "no state"

    header = f"[{role}]"
    lines.append(styled_line(header, width, fg=COL_AMBER, bg=COL_BG))
    lines.append(styled_line(f"state {status}", width, fg=status_color))
    lines.append(styled_line(f"model {model}", width))
    lines.append(styled_line(f"ctx {ctx} tok {tokens}", width))
    lines.append(styled_line(f"cost {cost}", width))
    lines.append(styled_line(short(lsp, width), width))
    lines.append(styled_line(f"cwd {cwd}", width, fg=COL_MUTED))
    lines.append(styled_line(age, width, fg=COL_MUTED))

    while len(lines) < height:
        lines.append(styled_line("", width))
    return lines[:height]


def draw_once():
    cols, rows = get_terminal_size((60, 20))
    cols = max(24, cols)
    rows = max(10, rows)

    top_h = rows // 2
    bot_h = rows - top_h

    main_data = read_state(STATE_MAIN)
    copilot_data = read_state(STATE_COPILOT)

    top = section("MAIN", main_data, cols, top_h)
    bot = section("COPILOT", copilot_data, cols, bot_h)

    out = "\x1b[H"
    out += "\n".join(top + bot)
    out += "\x1b[J"
    sys.stdout.write(out)
    sys.stdout.flush()


def main():
    signal.signal(signal.SIGINT, stop)
    signal.signal(signal.SIGTERM, stop)
    sys.stdout.write("\x1b[?25l\x1b[2J\x1b[H")
    sys.stdout.flush()
    try:
        while running:
            draw_once()
            time.sleep(REFRESH_SECONDS)
    finally:
        sys.stdout.write(COL_RESET + "\x1b[?25h")
        sys.stdout.flush()


if __name__ == "__main__":
    main()
