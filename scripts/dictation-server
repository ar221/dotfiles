<script>
let mediaRecorder = null;
let audioChunks = [];
let recording = false;
let rpMode = 0;
let durationInterval = null;
let recordStart = 0;
let lastRawText = '';       // raw whisper output (before RP formatting)
let lastUsedRp = 0;         // RP mode used for last result
let sessionLog = [];        // local mirror of server transcript
let selectedPersona = 'none';
let selectedCharacter = 'none';
let useRules = false;
let proseFormat = false;

const btn = document.getElementById('recordBtn');
const label = document.getElementById('recordLabel');
const resultArea = document.getElementById('resultArea');
const resultText = document.getElementById('resultText');
const durationEl = document.getElementById('duration');
const regenBtn = document.getElementById('regenBtn');

setRp(0);
loadTranscript();
loadPersonas();
loadCharacters();

function setRp(mode) {
  rpMode = mode;
  document.querySelectorAll('[data-rp]').forEach(el => {
    el.classList.toggle('active', parseInt(el.dataset.rp) === mode);
  });
  // Enable/disable RP+ controls
  const rpControls = document.getElementById('rpControls');
  rpControls.classList.toggle('disabled', mode !== 2);
}

function toggleRules() {
  useRules = !useRules;
  document.getElementById('rulesChip').classList.toggle('active', useRules);
}

function toggleProse() {
  proseFormat = !proseFormat;
  document.getElementById('proseChip').classList.toggle('active', proseFormat);
}

async function loadPersonas() {
  try {
    const resp = await fetch('/personas');
    const data = await resp.json();
    const select = document.getElementById('personaSelect');
    data.personas.forEach(p => {
      const opt = document.createElement('option');
      opt.value = p.id;
      opt.textContent = p.name;
      select.appendChild(opt);
    });
    // Auto-select first persona if available
    if (data.personas.length > 0) {
      select.value = data.personas[0].id;
      selectedPersona = data.personas[0].id;
    }
  } catch { /* ignore */ }
}

let allCharacters = [];

async function loadCharacters() {
  try {
    const resp = await fetch('/characters');
    const data = await resp.json();
    allCharacters = data.characters || [];
  } catch { /* ignore */ }
}

function showCharDropdown() {
  filterCharacters();
  document.getElementById('charDropdown').style.display = 'block';
}

function hideCharDropdown() {
  setTimeout(() => {
    document.getElementById('charDropdown').style.display = 'none';
  }, 200);
}

function filterCharacters() {
  const query = document.getElementById('characterSearch').value.toLowerCase();
  const dropdown = document.getElementById('charDropdown');
  const matches = query
    ? allCharacters.filter(c => c.name.toLowerCase().includes(query)).slice(0, 30)
    : allCharacters.slice(0, 30);

  let html = '<div class="char-opt char-none" onclick="selectCharacter(\'none\',\'No Character\')">No Character</div>';
  matches.forEach(c => {
    const esc = c.name.replace(/'/g, "\\'").replace(/"/g, '&quot;');
    html += `<div class="char-opt" onclick="selectCharacter('${esc}','${esc}')">${c.name.replace(/</g,'&lt;')}</div>`;
  });
  if (allCharacters.length > 30 && !query) {
    html += '<div class="char-opt char-none">Type to search ' + allCharacters.length + ' characters...</div>';
  }
  dropdown.innerHTML = html;
  dropdown.style.display = 'block';
}

function selectCharacter(id, name) {
  selectedCharacter = id;
  document.getElementById('characterSearch').value = (id === 'none') ? '' : name;
  document.getElementById('characterValue').value = id;
  document.getElementById('charDropdown').style.display = 'none';
  // Visual feedback
  const input = document.getElementById('characterSearch');
  input.classList.toggle('active', id !== 'none');
}

// Close dropdown on outside click
document.addEventListener('click', function(e) {
  if (!e.target.closest('#characterSearch') && !e.target.closest('#charDropdown')) {
    document.getElementById('charDropdown').style.display = 'none';
  }
});

function showToast(msg, ms = 2000) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), ms);
}

function formatDuration(sec) {
  const m = Math.floor(sec / 60);
  const s = Math.floor(sec % 60);
  return `${m}:${s.toString().padStart(2, '0')}`;
}

function setIcon(name) {
  document.getElementById('micIcon').style.display = name === 'mic' ? '' : 'none';
  document.getElementById('stopIcon').style.display = name === 'stop' ? '' : 'none';
  document.getElementById('spinnerIcon').style.display = name === 'spinner' ? '' : 'none';
}

function toggleContext() {
  const toggle = document.getElementById('contextToggle');
  const body = document.getElementById('contextBody');
  toggle.classList.toggle('open');
  body.classList.toggle('open');
}

function toggleLog() {
  const toggle = document.getElementById('logToggle');
  const body = document.getElementById('logBody');
  toggle.classList.toggle('open');
  body.classList.toggle('open');
}

function getContext() {
  return document.getElementById('contextInput').value.trim();
}

// ─── Recording ────────────────────────────────────────
async function toggleRecord() {
  if (recording) {
    stopRecording();
  } else {
    await startRecording();
  }
}

async function startRecording() {
  try {
    const stream = await navigator.mediaDevices.getUserMedia({
      audio: { sampleRate: 16000, channelCount: 1, echoCancellation: true, noiseSuppression: true }
    });

    const mimeType = MediaRecorder.isTypeSupported('audio/webm;codecs=opus')
      ? 'audio/webm;codecs=opus' : 'audio/webm';

    mediaRecorder = new MediaRecorder(stream, { mimeType });
    audioChunks = [];

    mediaRecorder.ondataavailable = e => {
      if (e.data.size > 0) audioChunks.push(e.data);
    };

    mediaRecorder.onstop = async () => {
      stream.getTracks().forEach(t => t.stop());
      clearInterval(durationInterval);
      await sendAudio();
    };

    mediaRecorder.start(100);
    recording = true;
    recordStart = Date.now();

    btn.classList.add('recording');
    btn.classList.remove('processing');
    setIcon('stop');
    label.textContent = 'Tap to stop';
    durationEl.classList.add('recording-dur');

    durationInterval = setInterval(() => {
      durationEl.textContent = formatDuration((Date.now() - recordStart) / 1000);
    }, 200);

  } catch (err) {
    console.error('Mic access error:', err);
    label.textContent = 'Microphone access denied';
    label.classList.add('error-text');
    setTimeout(() => {
      label.textContent = 'Tap to record';
      label.classList.remove('error-text');
    }, 3000);
  }
}

function stopRecording() {
  if (mediaRecorder && mediaRecorder.state !== 'inactive') {
    recording = false;
    mediaRecorder.stop();
    btn.classList.remove('recording');
    btn.classList.add('processing');
    setIcon('spinner');
    label.textContent = 'Transcribing...';
  }
}

async function sendAudio() {
  const blob = new Blob(audioChunks, { type: mediaRecorder.mimeType });

  const model = document.getElementById('modelSelect').value;
  const context = getContext();
  const params = new URLSearchParams({ model });
  if (rpMode > 0) params.set('rp', rpMode);
  if (context) params.set('context', context);
  if (rpMode === 2) {
    if (selectedPersona !== 'none') params.set('persona', selectedPersona);
    if (selectedCharacter !== 'none') params.set('character', selectedCharacter);
    if (useRules) params.set('rules', '1');
    if (proseFormat) params.set('prose', '1');
  }

  try {
    const resp = await fetch(`/transcribe?${params}`, {
      method: 'POST',
      headers: { 'Content-Type': mediaRecorder.mimeType },
      body: blob,
    });

    const data = await resp.json();

    if (data.error) {
      showError(data.error);
    } else {
      lastRawText = data.raw || data.text;
      lastUsedRp = rpMode;
      showResult(data.text);

      // Show regen button if RP+ was used
      regenBtn.style.display = (rpMode === 2) ? '' : 'none';

      // Update transcript display
      if (data.transcript_count !== undefined) {
        updateLogDisplay(data.transcript_count);
      }
    }
  } catch (err) {
    console.error('Transcription error:', err);
    showError('Connection error');
  }

  btn.classList.remove('processing');
  setIcon('mic');
  durationEl.classList.remove('recording-dur');
}

// ─── Regenerate ───────────────────────────────────────
async function regenerate() {
  if (!lastRawText) return;

  regenBtn.disabled = true;
  label.textContent = 'Regenerating...';
  btn.classList.add('processing');
  setIcon('spinner');

  const context = getContext();

  try {
    const resp = await fetch('/reformat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        text: lastRawText,
        rp: lastUsedRp || 2,
        context: context,
        persona: selectedPersona,
        character: selectedCharacter,
        rules: useRules,
        prose: proseFormat,
      }),
    });

    const data = await resp.json();

    if (data.error) {
      showError(data.error);
    } else {
      showResult(data.text);
      if (data.transcript_count !== undefined) {
        updateLogDisplay(data.transcript_count);
      }
    }
  } catch (err) {
    showError('Regen failed');
  }

  regenBtn.disabled = false;
  btn.classList.remove('processing');
  setIcon('mic');
  label.textContent = 'Tap to record';
}

// ─── Result display ───────────────────────────────────
function showResult(text) {
  resultText.textContent = text;
  resultArea.classList.add('visible');
  label.textContent = 'Tap to record';

  // Auto-copy
  navigator.clipboard.writeText(text)
    .then(() => showToast('Copied to clipboard'))
    .catch(() => showToast('Tap Copy to copy'));
}

function showError(msg) {
  label.textContent = msg;
  label.classList.add('error-text');
  setTimeout(() => {
    label.textContent = 'Tap to record';
    label.classList.remove('error-text');
  }, 3000);
}

async function copyResult() {
  try {
    await navigator.clipboard.writeText(resultText.textContent);
    showToast('Copied to clipboard');
  } catch {
    const ta = document.createElement('textarea');
    ta.value = resultText.textContent;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    showToast('Copied');
  }
}

function clearResult() {
  resultArea.classList.remove('visible');
  resultText.textContent = '';
  durationEl.textContent = '0:00';
  regenBtn.style.display = 'none';
  lastRawText = '';
}

// ─── Session log ──────────────────────────────────────
async function loadTranscript() {
  try {
    const resp = await fetch('/transcript');
    const data = await resp.json();
    sessionLog = data.transcript || [];
    renderLog();
  } catch { /* ignore */ }
}

function updateLogDisplay(count) {
  document.getElementById('logBadge').textContent = count;
  loadTranscript(); // refresh the full log
}

function renderLog() {
  const entries = document.getElementById('logEntries');
  const empty = document.getElementById('logEmpty');
  const badge = document.getElementById('logBadge');

  badge.textContent = sessionLog.length;

  if (sessionLog.length === 0) {
    empty.style.display = '';
    entries.innerHTML = '';
    return;
  }

  empty.style.display = 'none';
  entries.innerHTML = sessionLog.map(e => {
    const cls = e.role === 'context' ? 'context' : 'user';
    const roleLabel = e.role === 'context' ? 'Partner' : 'You';
    const text = e.text.length > 300 ? e.text.slice(0, 300) + '...' : e.text;
    return `<div class="log-entry ${cls}"><div class="log-role">${roleLabel}</div>${escHtml(text)}</div>`;
  }).join('');

  // Scroll to bottom
  const body = document.getElementById('logBody');
  body.scrollTop = body.scrollHeight;
}

function escHtml(s) {
  const d = document.createElement('div');
  d.textContent = s;
  return d.innerHTML;
}

async function clearSession() {
  try {
    await fetch('/transcript', { method: 'DELETE' });
    sessionLog = [];
    renderLog();
    showToast('Session cleared');
  } catch {
    showToast('Failed to clear');
  }
}
</script>
</body>
</html>
"""

PWA_MANIFEST = json.dumps({
    "name": "Dictate",
    "short_name": "Dictate",
    "start_url": "/",
    "display": "standalone",
    "background_color": "#121218",
    "theme_color": "#1a1a2e",
    "icons": [],
})


# ─── HTTP Handler ─────────────────────────────────────────
class DictationHandler(http.server.BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        log.info(fmt % args)

    def send_json(self, data: dict, status: int = 200):
        body = json.dumps(data).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(body)

    def send_html(self, html: str):
        body = html.encode()
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def read_json_body(self) -> dict:
        content_length = int(self.headers.get("Content-Length", 0))
        if content_length == 0:
            return {}
        return json.loads(self.rfile.read(content_length))

    def do_GET(self):
        path = urllib.parse.urlparse(self.path).path
        if path == "/":
            self.send_html(WEB_UI)
        elif path == "/manifest.json":
            body = PWA_MANIFEST.encode()
            self.send_response(200)
            self.send_header("Content-Type", "application/manifest+json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
        elif path == "/health":
            self.send_json({"status": "ok"})
        elif path == "/transcript":
            self.send_json({"transcript": session_transcript})
        elif path == "/personas":
            self.send_json({"personas": discover_personas()})
        elif path == "/characters":
            self.send_json({"characters": discover_characters()})
        else:
            self.send_response(404)
            self.end_headers()

    def do_DELETE(self):
        path = urllib.parse.urlparse(self.path).path
        if path == "/transcript":
            session_transcript.clear()
            log.info("Session transcript cleared")
            self.send_json({"status": "cleared"})
        else:
            self.send_response(404)
            self.end_headers()

    def do_POST(self):
        parsed = urllib.parse.urlparse(self.path)
        path = parsed.path
        params = urllib.parse.parse_qs(parsed.query)

        if path == "/transcribe":
            self._handle_transcribe(params)
        elif path == "/reformat":
            self._handle_reformat()
        else:
            self.send_response(404)
            self.end_headers()

    def _handle_reformat(self):
        """Re-run RP formatting on previously transcribed text."""
        try:
            data = self.read_json_body()
        except Exception:
            self.send_json({"error": "Invalid JSON"}, 400)
            return

        text = data.get("text", "").strip()
        rp = int(data.get("rp", 2))
        context = data.get("context", "")
        persona_id = data.get("persona", "")
        character_id = data.get("character", "")
        use_rules = bool(data.get("rules", False))
        prose_format = bool(data.get("prose", False))

        if not text:
            self.send_json({"error": "No text to reformat"}, 400)
            return

        # Remove the last user entry from transcript (we're replacing it)
        if session_transcript and session_transcript[-1]["role"] == "user":
            session_transcript.pop()

        # Run RP formatting with context
        formatted = format_rp(text, mode=rp, context=context,
                              persona_id=persona_id, use_rules=use_rules,
                              prose_format=prose_format,
                              character_id=character_id)

        # Add to transcript
        session_transcript.append({
            "role": "user",
            "text": formatted,
            "timestamp": datetime.now().isoformat(),
        })

        self.send_json({
            "text": formatted,
            "raw": text,
            "transcript_count": len(session_transcript),
        })

    def _handle_transcribe(self, params):
        """Transcribe audio and optionally format as RP."""
        model = params.get("model", [DEFAULT_MODEL])[0]
        rp = int(params.get("rp", ["0"])[0])
        context = urllib.parse.unquote(params.get("context", [""])[0])
        persona_id = params.get("persona", [""])[0]
        character_id = params.get("character", [""])[0]
        use_rules = params.get("rules", ["0"])[0] == "1"
        prose_format = params.get("prose", ["0"])[0] == "1"

        # Read audio body
        content_length = int(self.headers.get("Content-Length", 0))
        if content_length == 0:
            self.send_json({"error": "No audio data"}, 400)
            return

        audio_data = self.rfile.read(content_length)
        content_type = self.headers.get("Content-Type", "")

        tmp_input = None
        tmp_wav = None
        try:
            # Save the uploaded audio
            suffix = ".webm" if "webm" in content_type else ".wav"
            tmp_input = tempfile.NamedTemporaryFile(
                prefix="dictation-", suffix=suffix, dir="/tmp", delete=False
            )
            tmp_input.write(audio_data)
            tmp_input.close()

            # Convert to WAV (16kHz mono) if not already WAV
            wav_path = tmp_input.name
            if suffix != ".wav":
                tmp_wav = tempfile.NamedTemporaryFile(
                    prefix="dictation-", suffix=".wav", dir="/tmp", delete=False
                )
                tmp_wav.close()
                wav_path = tmp_wav.name

                ffmpeg_cmd = [
                    "ffmpeg", "-y", "-i", tmp_input.name,
                    "-ar", "16000", "-ac", "1", "-f", "wav",
                    wav_path,
                ]
                result = subprocess.run(
                    ffmpeg_cmd, capture_output=True, text=True, timeout=30
                )
                if result.returncode != 0:
                    self.send_json({"error": f"Audio conversion failed: {result.stderr[:200]}"}, 500)
                    return

            # Transcribe
            raw_text = transcribe(Path(wav_path), model=model)

            if not raw_text:
                self.send_json({"error": "No speech detected"}, 200)
                return

            # Add context to transcript if provided (RP+ only)
            if rp == 2 and context.strip():
                # Only add if different from last context entry
                if not session_transcript or session_transcript[-1].get("text") != context.strip():
                    session_transcript.append({
                        "role": "context",
                        "text": context.strip(),
                        "timestamp": datetime.now().isoformat(),
                    })

            # RP formatting
            output_text = raw_text
            if rp > 0:
                output_text = format_rp(raw_text, mode=rp, context=context,
                                       persona_id=persona_id, use_rules=use_rules,
                                       prose_format=prose_format,
                                       character_id=character_id)

            # Add to transcript (RP+ only)
            if rp == 2:
                session_transcript.append({
                    "role": "user",
                    "text": output_text,
                    "timestamp": datetime.now().isoformat(),
                })

            self.send_json({
                "text": output_text,
                "raw": raw_text,
                "transcript_count": len(session_transcript),
            })

        except FileNotFoundError as e:
            self.send_json({"error": str(e)}, 400)
        except RuntimeError as e:
            self.send_json({"error": str(e)}, 500)
        except Exception as e:
            log.exception("Transcription error")
            self.send_json({"error": f"Server error: {e}"}, 500)
        finally:
            if tmp_input:
                Path(tmp_input.name).unlink(missing_ok=True)
            if tmp_wav:
                Path(tmp_wav.name).unlink(missing_ok=True)

    def do_OPTIONS(self):
        """Handle CORS preflight."""
        self.send_response(204)
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, DELETE, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")
        self.end_headers()


# ─── Main ─────────────────────────────────────────────────
def main():
    parser = argparse.ArgumentParser(description="Remote dictation server")
    parser.add_argument("--port", type=int, default=DEFAULT_PORT, help=f"Port (default: {DEFAULT_PORT})")
    parser.add_argument("--host", default=DEFAULT_HOST, help=f"Host (default: {DEFAULT_HOST})")
    parser.add_argument("--no-ssl", action="store_true", help="Disable HTTPS (mic won't work on non-localhost)")
    args = parser.parse_args()

    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s [%(levelname)s] %(message)s",
        datefmt="%H:%M:%S",
    )

    # Verify dependencies
    if not shutil.which(WHISPER_BIN):
        log.error(f"{WHISPER_BIN} not found in PATH")
        raise SystemExit(1)
    if not shutil.which("ffmpeg"):
        log.error("ffmpeg not found — needed for audio format conversion")
        raise SystemExit(1)

    # Available models
    models = sorted(MODEL_DIR.glob("ggml-*.bin"))
    if not models:
        log.error(f"No whisper models found in {MODEL_DIR}")
        raise SystemExit(1)
    model_names = [m.stem.replace("ggml-", "") for m in models]
    log.info(f"Available models: {', '.join(model_names)}")

    server = http.server.HTTPServer((args.host, args.port), DictationHandler)

    if not args.no_ssl:
        ensure_ssl_cert()
        ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
        ctx.load_cert_chain(str(CERT_FILE), str(KEY_FILE))
        server.socket = ctx.wrap_socket(server.socket, server_side=True)
        proto = "https"
    else:
        proto = "http"

    # Get local IP for display
    import socket
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        local_ip = s.getsockname()[0]
        s.close()
    except Exception:
        local_ip = "127.0.0.1"

    log.info(f"Dictation server running at {proto}://{local_ip}:{args.port}")
    log.info(f"Open this URL on your phone to start dictating")
    if not args.no_ssl:
        log.info("First visit: accept the self-signed certificate warning")

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        log.info("Shutting down")
        server.shutdown()


if __name__ == "__main__":
    main()
