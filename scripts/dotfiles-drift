#!/usr/bin/env bash
set -euo pipefail

readonly SCRIPT_NAME="$(basename "$0")"
readonly VERSION="1.0.0"
readonly DOTFILES_REPO="$HOME/Github/dotfiles"
readonly INIR_REPO="$HOME/Github/inir"
readonly QUICKSHELL_LIVE="$HOME/.config/quickshell/ii"

# ─── Helpers ─────────────────────────────────────────────
info()  { printf '[\e[34mINFO\e[0m]  %s\n' "$*"; }
warn()  { printf '[\e[33mWARN\e[0m]  %s\n' "$*" >&2; }
error() { printf '[\e[31mERROR\e[0m] %s\n' "$*" >&2; }
die()   { error "$@"; exit 1; }

pass()  { printf '  [\e[32mSYNC\e[0m] %s\n' "$*"; }
drift() { printf '  [\e[33mDRIFT\e[0m] %s\n' "$*"; }

VERBOSE=0
NOTIFY=0
DRIFT_FOUND=0

usage() {
    cat <<EOF
Usage: $SCRIPT_NAME [OPTIONS]

Detect configuration drift between live configs and dotfiles repos.

Compares:
  ~/.config/{fish,kitty,niri,...} vs ~/Github/dotfiles/
  ~/.config/quickshell/ii/       vs ~/Github/inir/

Options:
    -v, --verbose    Show individual file differences
    --notify         Send desktop notification on drift
    -h, --help       Show this help
    -V, --version    Show version
EOF
}

# ─── Argument Parsing ────────────────────────────────────
while [[ $# -gt 0 ]]; do
    case "$1" in
        -v|--verbose) VERBOSE=1; shift ;;
        --notify)     NOTIFY=1; shift ;;
        -h|--help)    usage; exit 0 ;;
        -V|--version) echo "$VERSION"; exit 0 ;;
        *)            die "Unknown option: $1" ;;
    esac
done

# ─── Check Functions ─────────────────────────────────────
check_pair() {
    local label="$1"
    local live_path="$2"
    local repo_path="$3"

    if [[ ! -d "$live_path" ]]; then
        drift "$label — live path missing: $live_path"
        DRIFT_FOUND=1
        return
    fi
    if [[ ! -d "$repo_path" ]]; then
        drift "$label — repo path missing: $repo_path"
        DRIFT_FOUND=1
        return
    fi

    local diff_output
    diff_output=$(diff -rq "$live_path" "$repo_path" 2>/dev/null | grep -v '__pycache__' | grep -v '.pyc' || true)

    if [[ -z "$diff_output" ]]; then
        pass "$label"
    else
        local diff_count
        diff_count=$(echo "$diff_output" | wc -l)
        drift "$label — $diff_count file(s) differ"
        DRIFT_FOUND=1
        if [[ $VERBOSE -eq 1 ]]; then
            echo "$diff_output" | head -10 | sed 's/^/    /'
            [[ $diff_count -gt 10 ]] && printf '    ... and %d more\n' $((diff_count - 10))
        fi
    fi
}

check_file_pair() {
    local label="$1"
    local live_path="$2"
    local repo_path="$3"

    if [[ ! -f "$live_path" ]]; then
        drift "$label — live file missing"
        DRIFT_FOUND=1
        return
    fi
    if [[ ! -f "$repo_path" ]]; then
        drift "$label — repo file missing"
        DRIFT_FOUND=1
        return
    fi

    if diff -q "$live_path" "$repo_path" &>/dev/null; then
        pass "$label"
    else
        drift "$label — files differ"
        DRIFT_FOUND=1
    fi
}

# ─── Main ────────────────────────────────────────────────
main() {
    printf '\e[1;37m══ Dotfiles Drift Check ══\e[0m\n'
    printf '  %s\n\n' "$(date '+%Y-%m-%d %H:%M')"

    # Personal dotfiles (~/Github/dotfiles/) — repo stores configs directly, not under .config/
    printf '\e[1;36m── Personal Configs ──\e[0m\n'
    check_pair "Fish"     "$HOME/.config/fish"     "$DOTFILES_REPO/fish"
    check_pair "Kitty"    "$HOME/.config/kitty"    "$DOTFILES_REPO/kitty"
    check_pair "Niri"     "$HOME/.config/niri"     "$DOTFILES_REPO/niri"
    check_pair "Yazi"     "$HOME/.config/yazi"     "$DOTFILES_REPO/yazi"
    check_pair "Matugen"  "$HOME/.config/matugen"  "$DOTFILES_REPO/matugen"
    check_file_pair "Starship" "$HOME/.config/starship.toml" "$DOTFILES_REPO/starship/starship.toml"

    # Quickshell two-copy sync
    printf '\n\e[1;36m── Quickshell (iNiR) ──\e[0m\n'
    check_pair "Services" "$QUICKSHELL_LIVE/services" "$INIR_REPO/services"
    check_pair "Modules"  "$QUICKSHELL_LIVE/modules"  "$INIR_REPO/modules"
    check_pair "Scripts"  "$QUICKSHELL_LIVE/scripts"  "$INIR_REPO/scripts"

    # Summary
    printf '\n'
    # Append one-line status to drift log (fish greeting can read this)
    local log_file="$HOME/.cache/drift.log"
    if [[ $DRIFT_FOUND -eq 0 ]]; then
        info "All configs in sync"
        echo "$(date '+%Y-%m-%d %H:%M') CLEAN" > "$log_file"
    else
        warn "Drift detected — review and sync as needed"
        echo "$(date '+%Y-%m-%d %H:%M') DRIFT" > "$log_file"
        if [[ $NOTIFY -eq 1 ]] && command -v notify-send &>/dev/null; then
            notify-send "Dotfiles Drift" "Config drift detected. Run dotfiles-drift -v for details." \
                --app-name="dotfiles-drift" 2>/dev/null || true
        fi
    fi

    exit $DRIFT_FOUND
}

main "$@"
