#!/usr/bin/env bash
set -euo pipefail

# game-lookup — Look up game compatibility on ProtonDB, Steam, and PCGamingWiki
# Searches by name or Steam AppID, shows ratings and community-reported tweaks

readonly PROTONDB_API="https://www.protondb.com/api/v1/reports/summaries"
readonly PROTONDB_REPORTS="https://protondb.max-p.me/games"
readonly STEAM_SEARCH="https://store.steampowered.com/api/storesearch"
readonly PCGW_API="https://www.pcgamingwiki.com/api/appid.php"

# --- Helpers ---

info()  { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m::\033[0m %s\n' "$*" >&2; }
error() { printf '\033[1;31m::\033[0m %s\n' "$*" >&2; }
die()   { error "$@"; exit 1; }

usage() {
    cat <<'EOF'
Usage: game-lookup [options] <game name or AppID>

Look up game compatibility info from ProtonDB, Steam, and PCGamingWiki.

Options:
  --reports <n>     Show top N ProtonDB reports with tweaks (default: 5)
  --json            Output raw JSON (for scripting)
  --appid <id>      Skip search, use this Steam AppID directly
  -h, --help        Show this help

Examples:
  game-lookup "Elden Ring"
  game-lookup --appid 1245620
  game-lookup --reports 10 "Cyberpunk 2077"
  game-lookup "Skyrim Special Edition"
EOF
    exit "${1:-0}"
}

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "'$1' required but not installed"
}

# Color a ProtonDB tier
color_tier() {
    local tier="$1"
    case "$tier" in
        platinum) printf '\033[1;37m%s\033[0m' "$tier" ;;  # bright white
        gold)     printf '\033[1;33m%s\033[0m' "$tier" ;;  # gold/yellow
        silver)   printf '\033[1;37m%s\033[0m' "$tier" ;;  # silver
        bronze)   printf '\033[0;33m%s\033[0m' "$tier" ;;  # dim yellow
        borked)   printf '\033[1;31m%s\033[0m' "$tier" ;;  # red
        *)        printf '%s' "$tier" ;;
    esac
}

# --- Steam Search ---

steam_search() {
    local query="$1"
    local result
    result="$(curl -sf "${STEAM_SEARCH}/?term=$(printf '%s' "$query" | sed 's/ /+/g')&l=english&cc=US" 2>/dev/null)" || {
        warn "Steam search failed"
        return 1
    }

    local total
    total="$(echo "$result" | jq -r '.total // 0')"
    [[ "$total" -gt 0 ]] || { warn "No results on Steam for '$query'"; return 1; }

    echo "$result"
}

select_game() {
    local result="$1"
    local count
    count="$(echo "$result" | jq '.items | length')"

    if [[ "$count" -eq 1 ]]; then
        echo "$result" | jq '.items[0]'
        return
    fi

    echo "" >&2
    info "Multiple results found:" >&2
    for i in $(seq 0 $((count - 1))); do
        if [[ $i -ge 10 ]]; then
            warn "  ... and more (refine your search)" >&2
            break
        fi
        local name id
        name="$(echo "$result" | jq -r ".items[$i].name")"
        id="$(echo "$result" | jq -r ".items[$i].id")"
        printf '  \033[1;34m%2d\033[0m) %s (AppID: %s)\n' "$((i + 1))" "$name" "$id" >&2
    done

    echo "" >&2
    local choice
    read -rp "Select [1-${count}]: " choice >&2
    [[ "$choice" =~ ^[0-9]+$ ]] || die "invalid selection"
    choice=$((choice - 1))
    [[ $choice -ge 0 && $choice -lt $count ]] || die "out of range"

    echo "$result" | jq ".items[$choice]"
}

# --- ProtonDB ---

protondb_summary() {
    local appid="$1"
    curl -sf "${PROTONDB_API}/${appid}.json" 2>/dev/null || {
        warn "ProtonDB summary not available for AppID ${appid}"
        return 1
    }
}

protondb_reports() {
    local appid="$1" limit="${2:-5}"
    local result
    result="$(curl -sf "${PROTONDB_REPORTS}/${appid}/reports/" 2>/dev/null)" || {
        warn "ProtonDB reports not available"
        return 1
    }

    # Sort by timestamp (newest first) and take top N
    echo "$result" | jq --argjson limit "$limit" '
        sort_by(.timestamp) | reverse | .[:$limit]
    '
}

# --- Display ---

show_summary() {
    local name="$1" appid="$2" summary="$3"

    local tier trending score total confidence
    tier="$(echo "$summary" | jq -r '.tier // "unknown"')"
    trending="$(echo "$summary" | jq -r '.trendingTier // "unknown"')"
    score="$(echo "$summary" | jq -r '.score // "N/A"')"
    total="$(echo "$summary" | jq -r '.total // 0')"
    confidence="$(echo "$summary" | jq -r '.confidence // "unknown"')"

    echo ""
    printf '  \033[1m%s\033[0m (AppID: %s)\n' "$name" "$appid"
    echo "  ─────────────────────────────────"
    printf '  ProtonDB:   '; color_tier "$tier"; echo ""
    printf '  Trending:   '; color_tier "$trending"; echo ""
    printf '  Score:      %s / 1.0\n' "$score"
    printf '  Reports:    %s (%s confidence)\n' "$total" "$confidence"
    echo ""
    echo "  Links:"
    echo "    ProtonDB:    https://www.protondb.com/app/${appid}"
    echo "    PCGamingWiki: https://www.pcgamingwiki.com/api/appid.php?appid=${appid}"
    echo "    Steam:       https://store.steampowered.com/app/${appid}"
    echo ""
}

show_reports() {
    local reports="$1" limit="$2"

    local count
    count="$(echo "$reports" | jq 'length')"
    [[ "$count" -gt 0 ]] || { info "No detailed reports found"; return; }

    info "Top ${count} recent reports:"
    echo ""

    for i in $(seq 0 $((count - 1))); do
        local rating notes proton_ver os_name timestamp
        rating="$(echo "$reports" | jq -r ".[$i].rating // \"unknown\"")"
        notes="$(echo "$reports" | jq -r ".[$i].notes // \"(no notes)\"")"
        proton_ver="$(echo "$reports" | jq -r ".[$i].protonVersion // \"unknown\"")"
        os_name="$(echo "$reports" | jq -r ".[$i].os // \"unknown\"")"
        timestamp="$(echo "$reports" | jq -r ".[$i].timestamp // 0")"

        # Format timestamp
        local date_str="unknown"
        if [[ "$timestamp" != "0" && "$timestamp" != "null" ]]; then
            date_str="$(date -d "@${timestamp}" '+%Y-%m-%d' 2>/dev/null || echo "unknown")"
        fi

        printf '  \033[1;34m%d.\033[0m ' "$((i + 1))"
        color_tier "$rating"
        printf ' — Proton %s — %s — %s\n' "$proton_ver" "$os_name" "$date_str"

        # Print notes, word-wrapped and indented
        if [[ "$notes" != "(no notes)" && "$notes" != "null" ]]; then
            echo "$notes" | fold -s -w 76 | sed 's/^/     /'
        fi
        echo ""
    done
}

extract_tweaks() {
    local reports="$1"

    # Parse common patterns from report notes
    local notes_combined
    notes_combined="$(echo "$reports" | jq -r '.[].notes // empty' | tr '[:upper:]' '[:lower:]')"

    [[ -n "$notes_combined" ]] || return

    info "Common tweaks mentioned in reports:"
    echo ""

    # Check for common winetricks/dependencies
    local -A found_tweaks
    local patterns=(
        "vcrun:vcrun2019/vcrun2022 (Visual C++ Runtime)"
        "vcredist:vcrun2019 (Visual C++ Redistributable)"
        "dotnet:dotnet48/dotnet6 (.NET Framework)"
        "dxvk:dxvk (Vulkan D3D9/10/11)"
        "vkd3d:vkd3d (Vulkan D3D12)"
        "xact:xact_x64 (XACT Audio)"
        "xaudio:xaudio29 (XAudio2)"
        "corefonts:corefonts (Microsoft Core Fonts)"
        "fsr:WINE_FULLSCREEN_FSR=1 (AMD FSR upscaling)"
        "gamescope:gamescope (resolution/frame control)"
        "mangohud:MANGOHUD=1 (FPS overlay)"
        "gamemode:gamemoderun (CPU scheduling)"
        "ntsync:PROTON_USE_NTSYNC=1 (NTSync)"
        "proton-ge:Proton-GE (GloriousEggroll build)"
        "proton ge:Proton-GE (GloriousEggroll build)"
        "wayland:PROTON_ENABLE_WAYLAND=1"
        "wined3d:PROTON_USE_WINED3D=1 (OpenGL fallback)"
        "fullscreen:Fullscreen/windowed mode tweaks mentioned"
        "controller:Controller/gamepad tweaks mentioned"
        "shader:Shader compilation/cache mentioned"
        "lsfg:lsfg-vk (Frame Generation)"
        "frame gen:Frame generation mentioned"
    )

    for pattern_pair in "${patterns[@]}"; do
        local pattern="${pattern_pair%%:*}"
        local desc="${pattern_pair#*:}"
        if echo "$notes_combined" | grep -qi "$pattern" && [[ -z "${found_tweaks[$pattern]:-}" ]]; then
            found_tweaks[$pattern]=1
            echo "    - ${desc}"
        fi
    done

    # Check for env vars mentioned
    local env_patterns
    env_patterns="$(echo "$notes_combined" | grep -oE '[A-Z_]{3,}=[^ ]+' | sort -u | head -10)"
    if [[ -n "$env_patterns" ]]; then
        echo ""
        echo "  Environment variables mentioned:"
        while IFS= read -r var; do
            echo "    - ${var}"
        done <<< "$env_patterns"
    fi

    echo ""
}

# --- Main ---

require_cmd curl
require_cmd jq

report_count=5
raw_json=false
direct_appid=""
query=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --reports) report_count="$2"; shift 2 ;;
        --json)    raw_json=true; shift ;;
        --appid)   direct_appid="$2"; shift 2 ;;
        -h|--help) usage ;;
        -*)        die "unknown option: $1" ;;
        *)         query="${query:+${query} }$1"; shift ;;
    esac
done

[[ -n "$query" || -n "$direct_appid" ]] || die "game name or --appid required"

# Resolve AppID
appid=""
game_name=""

if [[ -n "$direct_appid" ]]; then
    appid="$direct_appid"
    # Get name from Steam
    local_details="$(curl -sf "https://store.steampowered.com/api/appdetails?appids=${appid}" 2>/dev/null || true)"
    game_name="$(echo "$local_details" | jq -r ".\"${appid}\".data.name // \"AppID ${appid}\"" 2>/dev/null || echo "AppID ${appid}")"
else
    info "Searching Steam for '${query}'..."
    search_result="$(steam_search "$query")" || die "search failed"

    game="$(select_game "$search_result")"
    appid="$(echo "$game" | jq -r '.id')"
    game_name="$(echo "$game" | jq -r '.name')"
fi

# Get ProtonDB summary
info "Looking up ProtonDB for '${game_name}' (AppID: ${appid})..."
summary="$(protondb_summary "$appid" || echo '{}')"

if $raw_json; then
    reports="$(protondb_reports "$appid" "$report_count" 2>/dev/null || echo '[]')"
    jq -n \
        --arg name "$game_name" \
        --arg appid "$appid" \
        --argjson summary "$summary" \
        --argjson reports "$reports" \
        '{name: $name, appid: $appid, summary: $summary, reports: $reports}'
    exit 0
fi

# Display
show_summary "$game_name" "$appid" "$summary"

# Get detailed reports
reports="$(protondb_reports "$appid" "$report_count" 2>/dev/null || echo '[]')"
report_len="$(echo "$reports" | jq 'length')"

if [[ "$report_len" -gt 0 ]]; then
    extract_tweaks "$reports"
    show_reports "$reports" "$report_count"
fi

# Suggest next steps
echo "─────────────────────────────────"
info "Quick setup:"
echo "  game-prefix create <name>"
echo "  game-prefix tricks <name> essentials    # vcrun2019 dotnet48 corefonts"
echo "  proton-run <name> /path/to/game.exe"
echo ""
