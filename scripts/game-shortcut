#!/usr/bin/env bash
set -euo pipefail

# game-shortcut — Create .desktop files for non-Steam games
# Games appear in your system launcher (rofi, wofi, fuzzel, etc.)

readonly APPS_DIR="${HOME}/.local/share/applications"
readonly PREFIXES_DIR="${HOME}/.local/share/game-prefixes"
readonly ICONS_DIR="${HOME}/.local/share/icons/games"

# --- Helpers ---

info()  { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m::\033[0m %s\n' "$*" >&2; }
error() { printf '\033[1;31m::\033[0m %s\n' "$*" >&2; }
die()   { error "$@"; exit 1; }

usage() {
    cat <<'EOF'
Usage: game-shortcut <command> [options]

Commands:
  create [options]            Create a .desktop shortcut
    --name <name>             Display name (required)
    --exe <path>              Path to executable (required)
    --prefix <prefix>         game-prefix name (required for Wine/Proton games)
    --icon <path>             Path to icon file (optional)
    --wine                    Use system Wine instead of Proton
    --wine-cachyos            Use Wine CachyOS (/opt/wine-cachyos)
    --mangohud                Enable MangoHud overlay
    --gamescope [args]        Enable gamescope (optional args in quotes)
    --lsfg                    Enable lsfg-vk frame generation
    --categories <cats>       Desktop categories (default: Game)
    --native                  Native Linux game (no Wine/Proton)
    --args <args>             Extra arguments to pass to the exe

  list                        List all game shortcuts
  remove <name>               Remove a shortcut
  edit <name>                 Open shortcut in $EDITOR

Desktop files: ~/.local/share/applications/game-*.desktop

Examples:
  game-shortcut create --name "Skyrim SE" --exe "/games/skyrim/SkyrimSE.exe" --prefix skyrim
  game-shortcut create --name "Cyberpunk" --exe "/games/cp2077/bin/x64/Cyberpunk2077.exe" \
    --prefix cyberpunk --mangohud --icon ~/Pictures/icons/cyberpunk.png
  game-shortcut create --name "Celeste" --exe "/games/celeste/Celeste" --native
  game-shortcut list
  game-shortcut remove skyrim-se
EOF
    exit "${1:-0}"
}

sanitize_name() {
    # Convert display name to a safe filename slug
    echo "$1" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/--*/-/g' | sed 's/^-//;s/-$//'
}

# --- Commands ---

cmd_create() {
    local name="" exe="" prefix="" icon="" use_wine=false use_wine_cachyos=false
    local mangohud=false gamescope=false gamescope_args="" lsfg=false
    local categories="Game" native=false extra_args=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --name)       name="$2"; shift 2 ;;
            --exe)        exe="$2"; shift 2 ;;
            --prefix)     prefix="$2"; shift 2 ;;
            --icon)       icon="$2"; shift 2 ;;
            --wine)       use_wine=true; shift ;;
            --wine-cachyos) use_wine_cachyos=true; shift ;;
            --mangohud)   mangohud=true; shift ;;
            --gamescope)
                gamescope=true
                if [[ "${2:-}" != --* ]] && [[ -n "${2:-}" ]]; then
                    gamescope_args="$2"; shift
                fi
                shift ;;
            --lsfg)       lsfg=true; shift ;;
            --categories) categories="$2"; shift 2 ;;
            --native)     native=true; shift ;;
            --args)       extra_args="$2"; shift 2 ;;
            -*)           die "unknown option: $1" ;;
            *)            die "unexpected argument: $1" ;;
        esac
    done

    [[ -n "$name" ]] || die "--name required"
    [[ -n "$exe" ]] || die "--exe required"

    if ! $native; then
        [[ -n "$prefix" ]] || die "--prefix required for Wine/Proton games (or use --native)"
        [[ -d "${PREFIXES_DIR}/${prefix}" ]] || die "prefix '${prefix}' not found (use 'game-prefix create ${prefix}')"
    fi

    local slug
    slug="$(sanitize_name "$name")"
    local desktop_file="${APPS_DIR}/game-${slug}.desktop"

    # Handle icon
    local icon_entry=""
    if [[ -n "$icon" ]]; then
        [[ -f "$icon" ]] || die "icon not found: ${icon}"
        mkdir -p "$ICONS_DIR"
        local ext="${icon##*.}"
        local icon_dest="${ICONS_DIR}/${slug}.${ext}"
        cp "$icon" "$icon_dest"
        icon_entry="Icon=${icon_dest}"
    else
        icon_entry="Icon=applications-games"
    fi

    # Build Exec line
    local exec_line=""
    # Quote exe path if it contains spaces
    local quoted_exe="$exe"
    [[ "$exe" == *" "* ]] && quoted_exe="\"${exe}\""

    if $native; then
        exec_line="${quoted_exe}"
        [[ -n "$extra_args" ]] && exec_line="${exec_line} ${extra_args}"

        if $mangohud; then
            exec_line="mangohud ${exec_line}"
        fi
        if $gamescope; then
            local gs="gamescope"
            [[ -n "$gamescope_args" ]] && gs="${gs} ${gamescope_args}"
            exec_line="${gs} -- ${exec_line}"
        fi
    else
        exec_line="proton-run"
        $use_wine && exec_line="${exec_line} --wine"
        $use_wine_cachyos && exec_line="${exec_line} --wine-cachyos"
        $mangohud && exec_line="${exec_line} --mangohud"
        $lsfg && exec_line="${exec_line} --lsfg"
        if $gamescope; then
            exec_line="${exec_line} --gamescope"
            [[ -n "$gamescope_args" ]] && exec_line="${exec_line} \"${gamescope_args}\""
        fi
        exec_line="${exec_line} ${prefix} ${quoted_exe}"
        [[ -n "$extra_args" ]] && exec_line="${exec_line} ${extra_args}"
    fi

    # Write .desktop file
    cat > "$desktop_file" <<DESKTOP
[Desktop Entry]
Type=Application
Name=${name}
Comment=Game launched via game-shortcut
Exec=${exec_line}
${icon_entry}
Categories=${categories};
Terminal=false
StartupNotify=false
DESKTOP

    chmod +x "$desktop_file"

    # Update desktop database if available
    if command -v update-desktop-database >/dev/null 2>&1; then
        update-desktop-database "$APPS_DIR" 2>/dev/null || true
    fi

    info "Created shortcut: ${desktop_file}"
    info "Name: ${name}"
    info "Exec: ${exec_line}"
    info "Should now appear in your launcher"
}

cmd_list() {
    local found=false
    printf '%-25s %-40s %s\n' "NAME" "EXEC" "FILE"
    printf '%-25s %-40s %s\n' "----" "----" "----"

    for f in "${APPS_DIR}"/game-*.desktop; do
        [[ -f "$f" ]] || continue
        found=true
        local dname dexec
        dname="$(grep '^Name=' "$f" | head -1 | cut -d= -f2-)"
        dexec="$(grep '^Exec=' "$f" | head -1 | cut -d= -f2-)"
        # Truncate exec for display
        [[ ${#dexec} -gt 38 ]] && dexec="${dexec:0:35}..."
        printf '%-25s %-40s %s\n' "$dname" "$dexec" "$(basename "$f")"
    done

    $found || info "No game shortcuts found"
}

cmd_remove() {
    local query="${1:-}"
    [[ -n "$query" ]] || die "shortcut name or slug required"

    local slug
    slug="$(sanitize_name "$query")"

    # Try exact match first, then partial
    local desktop_file="${APPS_DIR}/game-${slug}.desktop"
    if [[ ! -f "$desktop_file" ]]; then
        # Try finding by name
        desktop_file="$(grep -rl "^Name=${query}" "${APPS_DIR}"/game-*.desktop 2>/dev/null | head -1 || true)"
        [[ -n "$desktop_file" ]] || die "shortcut '${query}' not found"
    fi

    local dname
    dname="$(grep '^Name=' "$desktop_file" | head -1 | cut -d= -f2-)"
    rm -f "$desktop_file"
    info "Removed shortcut: ${dname} ($(basename "$desktop_file"))"

    if command -v update-desktop-database >/dev/null 2>&1; then
        update-desktop-database "$APPS_DIR" 2>/dev/null || true
    fi
}

cmd_edit() {
    local query="${1:-}"
    [[ -n "$query" ]] || die "shortcut name or slug required"

    local slug
    slug="$(sanitize_name "$query")"
    local desktop_file="${APPS_DIR}/game-${slug}.desktop"

    if [[ ! -f "$desktop_file" ]]; then
        desktop_file="$(grep -rl "^Name=${query}" "${APPS_DIR}"/game-*.desktop 2>/dev/null | head -1 || true)"
        [[ -n "$desktop_file" ]] || die "shortcut '${query}' not found"
    fi

    "${EDITOR:-nvim}" "$desktop_file"
}

# --- Main ---

[[ $# -gt 0 ]] || usage

cmd="$1"
shift

case "$cmd" in
    create)    cmd_create "$@" ;;
    list|ls)   cmd_list ;;
    remove|rm) cmd_remove "$@" ;;
    edit)      cmd_edit "$@" ;;
    help|-h|--help) usage ;;
    *)         die "unknown command: $cmd (try 'game-shortcut help')" ;;
esac
