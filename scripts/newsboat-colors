#!/usr/bin/env python3
"""Generate newsboat color config from matugen Material You colors.

Reads colors.json from quickshell state and writes newsboat-compatible
color directives using 256-color palette approximation.
"""

import json
from pathlib import Path

COLORS_JSON = Path.home() / ".local/state/quickshell/user/generated/colors.json"
OUTPUT = Path.home() / ".config/newsboat/colors"


def hex_to_rgb(h: str) -> tuple[int, int, int]:
    h = h.lstrip("#")
    return int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)


def rgb_to_256(r: int, g: int, b: int) -> int:
    """Convert RGB to nearest xterm-256 color index."""
    # Check greyscale ramp first (232-255)
    if r == g == b:
        if r < 8:
            return 16
        if r > 248:
            return 231
        return round((r - 8) / 247 * 24) + 232

    # Map to 6x6x6 color cube (indices 16-231)
    ri = round(r / 255 * 5)
    gi = round(g / 255 * 5)
    bi = round(b / 255 * 5)
    cube = 16 + 36 * ri + 6 * gi + bi

    # Check if greyscale is closer
    grey_avg = (r + g + b) // 3
    if grey_avg > 238:
        grey_idx = 231
    elif grey_avg < 8:
        grey_idx = 16
    else:
        grey_idx = round((grey_avg - 8) / 247 * 24) + 232

    # Compare distances
    cube_r, cube_g, cube_b = [v * 255 // 5 for v in (ri, gi, bi)]
    cube_dist = (r - cube_r) ** 2 + (g - cube_g) ** 2 + (b - cube_b) ** 2

    grey_val = 8 + ((grey_idx - 232) * 247 // 24) if 232 <= grey_idx <= 255 else (0 if grey_idx == 16 else 255)
    grey_dist = (r - grey_val) ** 2 + (g - grey_val) ** 2 + (b - grey_val) ** 2

    return grey_idx if grey_dist < cube_dist else cube


def c(name: str, colors: dict) -> str:
    """Convert a Material You color name to newsboat color<n> string."""
    r, g, b = hex_to_rgb(colors[name])
    return f"color{rgb_to_256(r, g, b)}"


def main():
    colors = json.loads(COLORS_JSON.read_text())

    surface = c("surface", colors)
    on_surface = c("on_surface", colors)
    primary = c("primary", colors)
    on_primary = c("on_primary", colors)
    primary_ctr = c("primary_container", colors)
    on_primary_ctr = c("on_primary_container", colors)
    secondary = c("secondary_container", colors)
    on_secondary = c("on_secondary_container", colors)
    tertiary = c("tertiary", colors)
    error = c("error", colors)
    variant = c("on_surface_variant", colors)

    lines = f"""\
# Newsboat Material You colors — generated by newsboat-colors
# Source: {COLORS_JSON}
# Do not edit — regenerated on wallpaper change

# base colors
color listnormal          {on_surface}  {surface}
color listfocus           {on_primary}  {primary}         bold
color listnormal_unread   {primary}     {surface}         bold
color listfocus_unread    {on_primary_ctr} {primary_ctr}  bold
color info                {on_secondary} {secondary}      bold
color article             {on_surface}  {surface}

# article highlights
highlight article "(^Feed:.*|^Title:.*|^Author:.*)" {primary} {surface} bold
highlight article "(^Link:.*|^Date:.*)" {variant} {surface}
highlight article "https?://[^ ]+" {tertiary} {surface} underline
highlight article "^(Title):.*$" {primary} {surface} bold
highlight article "\\\\[[0-9][0-9]*\\\\]" {secondary} {surface} bold
highlight article "\\\\[image\\\\ [0-9]+\\\\]" {tertiary} {surface} bold
highlight article "\\\\[embedded flash: [0-9][0-9]*\\\\]" {tertiary} {surface} bold
highlight article ":.*\\\\(link\\\\)$" {secondary} {surface}
highlight article ":.*\\\\(image\\\\)$" {tertiary} {surface}
highlight article ":.*\\\\(embedded flash\\\\)$" {secondary} {surface}

# list highlights
highlight articlelist "(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec) [0-9]+" {variant} {surface}
highlight articlelist "\\\\|[^\\\\|]+\\\\|" {secondary} {surface}
highlight articlelist "\\\\(YouTube\\\\)" {error} {surface}
highlight articlelist "\\\\(PeerTube\\\\)" {error} {surface}
highlight articlelist "\\\\|r/" {tertiary} {surface}
highlight feedlist "\\\\(YouTube\\\\)" {error} {surface}
highlight feedlist "\\\\(PeerTube\\\\)" {error} {surface}
highlight feedlist " r/" {tertiary} {surface}
highlight feedlist "\\\\([0-9]+/[0-9]+\\\\)" {variant} {surface}

highlight all "---.*---" {primary} {surface} bold
highlight feedlist "^.*\\\\(0/0\\\\)" {surface} {surface} invis
"""
    OUTPUT.write_text(lines)
    print(f"newsboat: wrote {OUTPUT}")


if __name__ == "__main__":
    main()
