#!/usr/bin/env bash
set -euo pipefail

# proton-run — Launch games through Proton or Wine with a managed prefix
# Works with prefixes created by game-prefix

readonly PREFIXES_DIR="${HOME}/.local/share/game-prefixes"
readonly COMPAT_DIRS=(
    "${HOME}/.local/share/Steam/compatibilitytools.d"
    "/usr/share/steam/compatibilitytools.d"
)
readonly STEAM_DIR="${HOME}/.local/share/Steam"
readonly WINE_CACHYOS="/opt/wine-cachyos/bin/wine"
readonly LSFG_VK_LAYER="VK_LAYER_lsfg_vk"

build_gs_args() {
    local gs_conf="$1"
    local GS_WIDTH="" GS_HEIGHT="" GS_OUTPUT_WIDTH="" GS_OUTPUT_HEIGHT=""
    local GS_FULLSCREEN="" GS_BORDERLESS="" GS_REFRESH="" GS_FPS_LIMIT=""
    local GS_SCALER="" GS_FILTER="" GS_SHARPNESS="" GS_HDR=""
    local GS_ADAPTIVE_SYNC="" GS_IMMEDIATE_FLIPS="" GS_RT="" GS_GRAB=""
    local GS_FORCE_GRAB_CURSOR="" GS_MANGOAPP="" GS_EXTRA=""
    # shellcheck disable=SC1090
    source "$gs_conf"

    local args=()
    [[ -n "$GS_OUTPUT_WIDTH" ]]          && args+=(-W "$GS_OUTPUT_WIDTH")
    [[ -n "$GS_OUTPUT_HEIGHT" ]]         && args+=(-H "$GS_OUTPUT_HEIGHT")
    [[ -n "$GS_WIDTH" ]]                 && args+=(-w "$GS_WIDTH")
    [[ -n "$GS_HEIGHT" ]]                && args+=(-h "$GS_HEIGHT")
    [[ -n "$GS_REFRESH" ]]               && args+=(-r "$GS_REFRESH")
    [[ "$GS_FULLSCREEN" == "1" ]]        && args+=(-f)
    [[ "$GS_BORDERLESS" == "1" ]]        && args+=(-b)
    [[ "$GS_GRAB" == "1" ]]             && args+=(-g)
    [[ -n "$GS_FPS_LIMIT" ]]            && args+=(--framerate-limit "$GS_FPS_LIMIT")
    [[ -n "$GS_SCALER" ]]               && args+=(-S "$GS_SCALER")
    [[ -n "$GS_FILTER" ]]               && args+=(-F "$GS_FILTER")
    [[ -n "$GS_SHARPNESS" ]]            && args+=(--sharpness "$GS_SHARPNESS")
    [[ "$GS_HDR" == "1" ]]              && args+=(--hdr-enabled)
    [[ "$GS_ADAPTIVE_SYNC" == "1" ]]    && args+=(--adaptive-sync)
    [[ "$GS_IMMEDIATE_FLIPS" == "1" ]]  && args+=(--immediate-flips)
    [[ "$GS_RT" == "1" ]]               && args+=(--rt)
    [[ "$GS_FORCE_GRAB_CURSOR" == "1" ]] && args+=(--force-grab-cursor)
    [[ "$GS_MANGOAPP" == "1" ]]         && args+=(--mangoapp)
    # shellcheck disable=SC2206
    [[ -n "$GS_EXTRA" ]]                && args+=($GS_EXTRA)

    echo "${args[*]}"
}

find_proton() {
    local version="$1"
    local dir
    for dir in "${COMPAT_DIRS[@]}"; do
        if [[ -d "${dir}/${version}" ]]; then
            echo "${dir}/${version}"
            return
        fi
    done
    die "Proton '${version}' not found in: ${COMPAT_DIRS[*]}"
}

# --- Helpers ---

info()  { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m::\033[0m %s\n' "$*" >&2; }
error() { printf '\033[1;31m::\033[0m %s\n' "$*" >&2; }
die()   { error "$@"; exit 1; }

usage() {
    cat <<'EOF'
Usage: proton-run [options] <prefix> <exe> [args...]

Launch a Windows executable using a game-prefix.

Options:
  --wine              Use system Wine instead of Proton
  --wine-cachyos      Use Wine CachyOS (/opt/wine-cachyos/bin/wine)
  --proton <version>  Override Proton version for this run
  --gamescope [args]  Wrap in gamescope (optional args in quotes)
  --mangohud          Enable MangoHud overlay
  --gamemode          Enable Feral GameMode (if installed)
  --lsfg              Enable lsfg-vk frame generation
  --dry-run           Print the command without executing
  --verbose           Show environment details before launch
  -h, --help          Show this help

Environment:
  Per-game env vars are loaded from <prefix>/config.env
  Override anything with standard env: VAR=val proton-run ...

Examples:
  proton-run skyrim ./SkyrimSE.exe
  proton-run --mangohud --gamescope "-w 2560 -h 1440 -f" cyberpunk ./REDprelauncher.exe
  proton-run --wine-cachyos modded-fo4 ./Fallout4.exe -windowed
  proton-run --lsfg --mangohud elden-ring ./eldenring.exe
  MANGOHUD=1 proton-run elden-ring ./eldenring.exe
EOF
    exit "${1:-0}"
}

# --- Main ---

use_wine=false
use_wine_cachyos=false
proton_override=""
gamescope=false
gamescope_args=""
mangohud=false
gamemode=false
lsfg=false
dry_run=false
verbose=false
prefix_name=""
exe=""
exe_args=()

# Parse options
while [[ $# -gt 0 ]]; do
    case "$1" in
        --wine)      use_wine=true; shift ;;
        --wine-cachyos) use_wine_cachyos=true; shift ;;
        --proton)    proton_override="$2"; shift 2 ;;
        --gamescope)
            gamescope=true
            if [[ "${2:-}" != -* ]] && [[ -n "${2:-}" ]] && [[ "${2:-}" != */* ]]; then
                gamescope_args="$2"; shift
            fi
            shift ;;
        --mangohud)  mangohud=true; shift ;;
        --gamemode)  gamemode=true; shift ;;
        --lsfg)      lsfg=true; shift ;;
        --dry-run)   dry_run=true; shift ;;
        --verbose)   verbose=true; shift ;;
        -h|--help)   usage ;;
        -*)          die "unknown option: $1" ;;
        *)
            if [[ -z "$prefix_name" ]]; then
                prefix_name="$1"
            elif [[ -z "$exe" ]]; then
                exe="$1"
            else
                exe_args+=("$1")
            fi
            shift ;;
    esac
done

[[ -n "$prefix_name" ]] || die "prefix name required (try 'proton-run --help')"
[[ -n "$exe" ]] || die "executable path required"

# Resolve prefix
pdir="${PREFIXES_DIR}/${prefix_name}"
[[ -d "$pdir" ]] || die "prefix '${prefix_name}' not found (use 'game-prefix create ${prefix_name}')"

# Load prefix metadata
PROTON_VERSION=""
WINEARCH="win64"
WINE_BACKEND=""
if [[ -f "${pdir}/prefix.conf" ]]; then
    # shellcheck disable=SC1090
    source "${pdir}/prefix.conf"
fi

# Override Proton if requested
[[ -n "$proton_override" ]] && PROTON_VERSION="$proton_override"

# Auto-detect wine-cachyos from prefix config
[[ "${WINE_BACKEND:-}" == "wine-cachyos" ]] && use_wine_cachyos=true

# Load per-game env vars (these can override mangohud, gamescope, etc.)
if [[ -f "${pdir}/config.env" ]]; then
    # shellcheck disable=SC1090
    source "${pdir}/config.env"
fi

# Apply flags from config.env if set there
[[ "${MANGOHUD:-}" == "1" ]] && mangohud=true
[[ "${ENABLE_GAMESCOPE:-}" == "1" ]] && gamescope=true
[[ -n "${GAMESCOPE_ARGS:-}" ]] && gamescope_args="${GAMESCOPE_ARGS}"
[[ "${ENABLE_LSFG:-}" == "1" ]] && lsfg=true

# Load per-game gamescope config (from game-prefix gamescope)
gs_conf="${pdir}/gamescope.conf"
if [[ -f "$gs_conf" ]]; then
    if ! $gamescope; then
        # Auto-enable gamescope when prefix has a gamescope.conf
        gamescope=true
    fi
    if [[ -z "$gamescope_args" ]]; then
        gamescope_args="$(build_gs_args "$gs_conf")"
    fi
fi

# Set up Wine/Proton environment
export WINEPREFIX="${pdir}/pfx"
export WINEARCH
export STEAM_COMPAT_DATA_PATH="${pdir}"
export STEAM_COMPAT_CLIENT_INSTALL_PATH="${STEAM_DIR}"

# Enable lsfg-vk frame generation via Vulkan layer
if $lsfg; then
    command -v lsfg-vk-cli >/dev/null 2>&1 || die "lsfg-vk not installed (paru -S lsfg-vk-git)"
    # Add lsfg-vk to the Vulkan implicit layer list
    if [[ -n "${VK_INSTANCE_LAYERS:-}" ]]; then
        export VK_INSTANCE_LAYERS="${VK_INSTANCE_LAYERS}:${LSFG_VK_LAYER}"
    else
        export VK_INSTANCE_LAYERS="${LSFG_VK_LAYER}"
    fi
    export ENABLE_LSFG_VK=1
fi

# Build the launch command
launch_cmd=()

# Gamescope wrapper
if $gamescope; then
    command -v gamescope >/dev/null 2>&1 || die "gamescope not installed"
    launch_cmd+=(gamescope)
    if [[ -n "$gamescope_args" ]]; then
        # shellcheck disable=SC2206
        launch_cmd+=($gamescope_args)
    fi
    launch_cmd+=(--)
fi

# GameMode wrapper
if $gamemode; then
    command -v gamemoderun >/dev/null 2>&1 || die "gamemode not installed (pacman -S gamemode)"
    launch_cmd+=(gamemoderun)
fi

# MangoHud wrapper
if $mangohud; then
    command -v mangohud >/dev/null 2>&1 || die "mangohud not installed"
    launch_cmd+=(mangohud)
fi

if $use_wine_cachyos; then
    # Wine CachyOS mode
    [[ -x "$WINE_CACHYOS" ]] || die "wine-cachyos-opt not installed (paru -S wine-cachyos-opt)"
    export PATH="/opt/wine-cachyos/bin:${PATH}"

    # Initialize prefix if needed
    if [[ ! -d "${pdir}/pfx/drive_c" ]]; then
        info "First run — initializing prefix with Wine CachyOS..."
        "$WINE_CACHYOS" wineboot --init 2>/dev/null || true
    fi

    launch_cmd+=("$WINE_CACHYOS" "$exe" "${exe_args[@]}")
elif $use_wine; then
    # System Wine mode
    launch_cmd+=(wine "$exe" "${exe_args[@]}")
else
    # Proton mode
    [[ -n "$PROTON_VERSION" ]] || die "no Proton version set (check prefix.conf or use --proton)"
    proton_dir="$(find_proton "$PROTON_VERSION")"

    proton_bin="${proton_dir}/proton"
    [[ -x "$proton_bin" ]] || die "Proton binary not executable: ${proton_bin}"

    # Initialize prefix if it hasn't been yet
    if [[ ! -d "${pdir}/pfx/drive_c" ]]; then
        info "First run — initializing prefix..."
        "${proton_bin}" run wineboot --init 2>/dev/null || true
    fi

    launch_cmd+=("${proton_bin}" run "$exe" "${exe_args[@]}")
fi

if $verbose; then
    info "Prefix:    ${prefix_name} (${pdir})"
    if $use_wine_cachyos; then
        info "Backend:   Wine CachyOS (/opt/wine-cachyos/bin/wine)"
    elif $use_wine; then
        info "Backend:   system wine"
    else
        info "Proton:    ${PROTON_VERSION}"
    fi
    info "Arch:      ${WINEARCH}"
    info "Exe:       ${exe}"
    info "Args:      ${exe_args[*]:-none}"
    info "MangoHud:  ${mangohud}"
    info "Gamescope: ${gamescope} ${gamescope_args}"
    info "GameMode:  ${gamemode}"
    info "lsfg-vk:   ${lsfg}"
    info "Command:   ${launch_cmd[*]}"
    echo ""
fi

if $dry_run; then
    echo "${launch_cmd[*]}"
    exit 0
fi

info "Launching ${exe##*/} in prefix '${prefix_name}'..."
exec "${launch_cmd[@]}"
