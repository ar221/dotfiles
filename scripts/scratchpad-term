#!/usr/bin/env bash
set -euo pipefail

# scratchpad-term — Toggle a floating kitty scratchpad terminal
# Usage: scratchpad-term [command]
#   No args:     toggle kitty-scratchpad (plain shell)
#   With args:   toggle kitty-<command> running that command
#   e.g. scratchpad-term newsboat → app-id kitty-newsboat, runs newsboat

info()  { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m::\033[0m %s\n' "$*" >&2; }
error() { printf '\033[1;31m::\033[0m %s\n' "$*" >&2; }
die()   { error "$@"; exit 1; }

command -v niri  >/dev/null 2>&1 || die "'niri' not found in PATH"
command -v kitty >/dev/null 2>&1 || die "'kitty' not found in PATH"
command -v jq    >/dev/null 2>&1 || die "'jq' not found in PATH"

CMD="${1:-}"
if [[ -n "$CMD" ]]; then
    APP_ID="kitty-${CMD}"
else
    APP_ID="kitty-scratchpad"
fi

window_id=$(niri msg -j windows 2>/dev/null \
    | jq -r --arg id "$APP_ID" '.[] | select(.app_id == $id) | .id' \
    | head -n1)

if [[ -n "$window_id" ]]; then
    info "Focusing existing $APP_ID (id=$window_id)"
    niri msg action focus-window --id "$window_id"
else
    info "Spawning $APP_ID"
    if [[ -n "$CMD" ]]; then
        kitty --class "$APP_ID" --detach -e "$CMD"
    else
        kitty --class "$APP_ID" --detach
    fi
fi
