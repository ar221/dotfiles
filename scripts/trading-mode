#!/usr/bin/env bash
set -euo pipefail

# trading-mode — Set up a trading workspace layout on niri
#
# Usage:
#   trading-mode enter [--news]
#   trading-mode exit
#   trading-mode status

readonly VERSION="0.1.0"
readonly STATE_FILE="$HOME/.cache/trading-session/active"

# --- Helpers ---

info()  { printf '\033[1;34m::\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m::\033[0m %s\n' "$*" >&2; }
error() { printf '\033[1;31m::\033[0m %s\n' "$*" >&2; }
die()   { error "$@"; exit 1; }

usage() {
    cat <<'EOF'
Usage: trading-mode <command> [options]

Commands:
  enter [--news]   Open trading workspaces (TradingView + kitty terminal)
  exit             Notify to close windows manually (no global kill)
  status           Check if kitty-trading window is running

Options:
  --news           Also open a news tab in Firefox on workspace 3
  -h, --help       Show this help
  -V, --version    Show version
EOF
    exit "${1:-0}"
}

# --- Subcommands ---

cmd_enter() {
    local open_news=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --news)    open_news=true; shift ;;
            -h|--help) usage 0 ;;
            *)         die "unknown option: $1" ;;
        esac
    done

    if [[ -f "$STATE_FILE" ]]; then
        warn "Trading mode already entered (state file exists)"
        cmd_status
        info "Run 'trading-mode exit' to clear state, then re-enter"
        exit 0
    fi

    mkdir -p "$(dirname "$STATE_FILE")"

    # Workspace 1 — TradingView in Firefox
    info "Focusing workspace 1..."
    niri msg action focus-workspace 1
    sleep 0.3
    info "Opening TradingView..."
    firefox --new-window "https://www.tradingview.com/chart/" &
    disown
    sleep 0.3

    # Workspace 2 — kitty with class kitty-trading
    info "Focusing workspace 2..."
    niri msg action focus-workspace 2
    sleep 0.3
    info "Opening trading terminal..."
    kitty --class kitty-trading &
    disown
    sleep 0.3

    # Workspace 3 — news tab (optional)
    if $open_news; then
        info "Focusing workspace 3..."
        niri msg action focus-workspace 3
        sleep 0.3
        info "Opening news tab..."
        firefox --new-window "https://finance.yahoo.com/" &
        disown
        sleep 0.3
    fi

    # Return focus to workspace 1 (TradingView)
    info "Returning focus to workspace 1..."
    niri msg action focus-workspace 1

    # Write state
    cat > "$STATE_FILE" <<EOF
started=$(date -Iseconds)
news=$open_news
EOF

    echo ""
    info "Trading workspace ready"
    info "  WS 1: TradingView (Firefox)"
    info "  WS 2: kitty-trading terminal"
    if $open_news; then
        info "  WS 3: News (Firefox)"
    fi
    notify-send -a "Trading Mode" "Trading Mode" "Workspace ready" 2>/dev/null || true
}

cmd_exit() {
    if [[ ! -f "$STATE_FILE" ]]; then
        info "Trading mode is not active"
        return 0
    fi

    rm -f "$STATE_FILE"
    info "Trading mode state cleared"
    info "Close TradingView and terminal windows manually when done"
    notify-send -a "Trading Mode" "Trading Mode" "Session ended — close windows manually" 2>/dev/null || true
}

cmd_status() {
    echo ""
    if [[ -f "$STATE_FILE" ]]; then
        info "Trading mode: ACTIVE"
        while IFS='=' read -r key val; do
            case "$key" in
                started) info "  Started: $val" ;;
                news)    info "  News WS: $val" ;;
            esac
        done < "$STATE_FILE"
    else
        info "Trading mode: inactive"
    fi

    echo ""
    if niri msg -j windows 2>/dev/null | python3 -c "
import json, sys
wins = json.load(sys.stdin)
found = any(w.get('app_id') == 'kitty-trading' for w in wins)
sys.exit(0 if found else 1)
" 2>/dev/null; then
        info "  kitty-trading: running"
    else
        info "  kitty-trading: not found"
    fi
}

# --- Main ---

case "${1:-}" in
    enter)      shift; cmd_enter "$@" ;;
    exit)       shift; cmd_exit "$@" ;;
    status)     shift; cmd_status "$@" ;;
    -h|--help)  usage 0 ;;
    -V|--version) echo "trading-mode $VERSION"; exit 0 ;;
    "")         usage 0 ;;
    *)          die "unknown command: $1 (try 'trading-mode --help')" ;;
esac
