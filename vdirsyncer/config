# vdirsyncer configuration — Google Calendar via CalDAV
# Setup: https://vdirsyncer.pimutils.org/en/stable/config.html
#
# FIRST-TIME SETUP:
#   1. Replace CLIENT_ID and CLIENT_SECRET below with your Google OAuth credentials
#      (create at https://console.cloud.google.com/apis/credentials — "Desktop app" type,
#       enable "Google Calendar API" under APIs & Services > Library)
#   2. Run: vdirsyncer discover google_calendar
#      — this opens a browser for Google OAuth consent
#   3. Run: vdirsyncer sync
#   4. Enable the timer: systemctl --user enable --now calendar-sync.timer

[general]
status_path = "~/.local/share/vdirsyncer/status/"

[pair google_calendar]
a = "google_calendar_local"
b = "google_calendar_remote"
collections = ["from a", "from b"]
metadata = ["color", "displayname"]
conflict_resolution = "b wins"

[storage google_calendar_local]
type = "filesystem"
path = "~/.local/share/calendars/google/"
fileext = ".ics"

[storage google_calendar_remote]
type = "google_calendar"
token_file = "~/.local/share/vdirsyncer/google_token"
client_id = "YOUR_CLIENT_ID.apps.googleusercontent.com"
client_secret = "YOUR_CLIENT_SECRET"
